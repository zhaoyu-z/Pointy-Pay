# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Circle
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Arc Testnet RPC (optional, defaults to public key)
ARC_TESTNET_RPC_KEY=

# Payout executor private key (EOA used to sign Gateway burn intents and execute mints)
# The address derived from this key must have USDC deposited in the Arc Gateway Wallet
PAYOUT_EXECUTOR_PRIVATE_KEY=
